      "registryBaseUrl": "https://api.nuget.org",
      "identifier": "OpenRouterMcp",
      "version": "0.0.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        "mcp"
      ],
      "environmentVariables": []
    }
  ],
  "repository": {
    "url": "https://github.com/brendankowitz/dotnet-openrouter",
    "source": "github"
  }
}
